{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "shellcheck *": "allow",
      "jq *": "allow"
    }
  },
  "instructions": ["https://raw.githubusercontent.com/redbaron/agents/main/AGENTS.md"],
  "autoupdate": "notify",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}
